{% if customer and customer.orders_count > 0 %}
  <div class="vrm-check">
    <iframe
      id="vrm-check-iframe"
      src="https://key-library-vrm-check-theta.vercel.app/?customer_id={{ customer.id }}&email={{ customer.email | url_encode }}"
      width="100%"
      height="400"
      style="border: none; width: 100%; display: block; overflow: hidden;"
      title="vrm check"
      scrolling="no"
      allowfullscreen>
    </iframe>
  </div>
  <script>
    window.addEventListener('message', function (event) {
      if (!event.data || event.data.type !== 'vrm-check-resize') return;
      var iframe = document.getElementById('vrm-check-iframe');
      if (!iframe) return;
      var height = Number(event.data.height) || 0;
      if (height > 0) {
        iframe.style.height = height + 'px';
      }
    });
  </script>
{% elsif customer and customer.orders_count == 0 %}
  <div style="text-align: center; margin: 35px 0;">
    <p class="no-orders" style="color: red;font-weight: bold;margin: 0 20px;">Users must have at least one completed order to access the registration checker.</p>
  </div>
{% else %}
  <div style="display: flex; justify-content: center; margin: 35px 0;">
    <a href="https://www.keylibrary.co.uk/account/login" class="log-reg button button--secondary">
      Login/Register To View
    </a>
  </div>
{% endif %}
<style>
.vrm-check iframe { overflow: hidden; }
@media(min-width:768px){
 .no-orders{   font-size: 22px; }
}
</style>
