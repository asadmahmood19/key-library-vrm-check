# External Vehicle API (CheckCarDetails)
VEHICLE_API_KEY=

# Admin Dashboard Password
ADMIN_PASSWORD=

# Neon Postgres connection string
DATABASE_URL=

# How long cached VRM lookups remain valid
CACHE_DURATION_DAYS=7

# Placeholder Buy Credits redirect (swap for Shopify product URL later)
BUY_CREDITS_URL=https://www.keylibrary.co.uk/

# Cookie session signing secret (use a long random string in production)
SESSION_SECRET=

# Local server port
PORT=3000

# £ of order total required for 1 lookup credit (default: £10 = 1 credit)
CREDITS_POUNDS_PER_CREDIT=10

# Only count Shopify orders on/after this date (YYYY-MM-DD)
CREDITS_START_DATE=2026-07-22
